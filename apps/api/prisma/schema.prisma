generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserAccount {
  id           String   @id @default(cuid())
  principal    String   @unique
  passwordHash String
  role         String
  displayName  String
  status       String
  createdAt    DateTime @default(now())
}

model StudentProfile {
  id                      String   @id @default(cuid())
  userId                  String
  nickname                String
  grade                   Int
  preferredSessionMinutes Int
  chineseVersionId        String
  mathVersionId           String
  englishVersionId        String
  createdAt               DateTime @default(now())
}

model SubjectEnrollment {
  id               String   @id @default(cuid())
  studentId        String
  subject          String
  enabled          Boolean
  textbookVersionId String
  createdAt        DateTime @default(now())
}

model TextbookVolume {
  id               String   @id @default(cuid())
  subject          String
  publisherVersion String
  grade            Int
  term             String
  displayName      String
  sourcePath       String
  status           String
  createdAt        DateTime @default(now())
}

model KnowledgePoint {
  id              String   @id @default(cuid())
  subject         String
  name            String
  parentId        String?
  gradeBand       String
  difficultyLevel Int
  lessonId        String?
  status          String
  createdAt       DateTime @default(now())
}

model Question {
  id              String   @id @default(cuid())
  subject         String
  type            String
  stem            String
  answer          Json
  analysis        String
  difficultyLevel Int
  status          String
  createdAt       DateTime @default(now())
}

model QuestionDocument {
  id                  String   @id @default(cuid())
  questionId          String   @unique
  version             Int
  locale              String
  blocks              Json
  attachments         Json
  layoutMode          String
  accessibilityConfig Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model QuestionAnswerSchema {
  id              String   @id @default(cuid())
  questionId      String   @unique
  mode            String
  responseShape   Json
  validationRules Json
  gradingConfig   Json
  options         Json?
  placeholder     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QuestionSourceRecord {
  id              String   @id @default(cuid())
  questionId      String   @unique
  sourceType      String
  sourceName      String
  sourcePathOrUrl String
  licenseClass    String
  licenseName     String?
  importJobId     String?
  reviewStatus    String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QuestionImportJob {
  id              String   @id @default(cuid())
  importType      String
  subject         String
  sourcePathOrUrl String
  sourceType      String
  licenseClass    String
  licenseName     String?
  status          String
  fileCount       Int      @default(0)
  recordCount     Int      @default(0)
  warningCount    Int      @default(0)
  errorMessage    String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?
}

model QuestionImportRecord {
  id                 String   @id @default(cuid())
  jobId              String
  subject            String
  sourcePath         String
  sourceName         String
  pageNumber         Int?
  candidateIndexOnPage Int
  splitMode          String
  sectionLabel       String?
  qualityLevel       String
  qualityFlagsJson   String
  excerpt            String
  previewImageDataUrl String?
  detectionReason    String
  candidateStem      String
  aiSuggestionJson   String?
  aiSuggestedAt      DateTime?
  reviewStatus       String
  reviewComment      String?
  candidateQuestionId String?
  createdAt          DateTime @default(now())
  reviewedAt         DateTime?
}

model AssessmentSession {
  id             String   @id @default(cuid())
  studentId      String
  subject        String
  assessmentType String
  status         String
  startedAt      DateTime
  completedAt    DateTime?
}

model DailyMission {
  id                     String   @id @default(cuid())
  studentId              String
  subject                String
  missionType            String
  title                  String
  estimatedMinutes       Int
  status                 String
  createdAt              DateTime @default(now())
}

model AssistantSession {
  id             String   @id @default(cuid())
  userRole       String
  studentId      String?
  pageContext    String
  contextRefType String?
  contextRefId   String?
  status         String
  createdAt      DateTime @default(now())
}
