{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@study-agent/contracts": [
        "packages/contracts/src"
      ],
      "@study-agent/config": [
        "packages/config/src"
      ],
      "@study-agent/ui": [
        "packages/ui/src"
      ]
    }
  }
}

